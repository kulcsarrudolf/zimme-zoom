{
  "name": "zimme-zoom",
  "version": "0.2.3",
  "description": "A collection of image-related React components packaged as an npm package. The main component is PhotoViewer, a lightweight React photo viewer with zoom, navigation, blurred background, and SVG overlay support",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn clean && rollup -c",
    "build:npm": "npm run clean && rollup -c",
    "build:storybook": "storybook build",
    "build:vercel": "storybook build",
    "dev": "rollup -c -w",
    "clean": "rimraf dist",
    "test": "jest --passWithNoTests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "prepublishOnly": "npm run build:npm && npm test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy": "bash scripts/release.sh",
    "deploy:minor": "bash scripts/release.sh minor",
    "deploy:major": "bash scripts/release.sh major"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-links": "^10.1.11",
    "@storybook/react": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-storybook": "10.1.11",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.2.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.9.6",
    "rollup-plugin-typescript2": "^0.36.0",
    "storybook": "^10.1.11",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.2.6"
  },
  "keywords": [
    "react",
    "photo-viewer",
    "zoom",
    "image-viewer",
    "lightbox",
    "svg-overlay",
    "gallery",
    "image",
    "image-gallery"
  ],
  "author": "Kulcsar Rudolf <kulcsarrudolf@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kulcsarrudolf/zimme-zoom.git"
  },
  "bugs": {
    "url": "https://github.com/kulcsarrudolf/zimme-zoom/issues"
  },
  "homepage": "https://github.com/kulcsarrudolf/zimme-zoom#readme",
  "engines": {
    "node": ">=14.0.0",
    "yarn": ">=1.22.0"
  }
}
